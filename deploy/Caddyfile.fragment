#     }
#
#     # SPA static assets (existing rules) — only matches when nothing above did
#     handle {
#         @assets path /assets/*
#         header @assets Cache-Control "public, max-age=31536000, immutable"
#
#         @sw path /sw.js /registerSW.js /workbox-*.js
#         header @sw Cache-Control "no-cache, no-store, must-revalidate"
#
#         @root path / /index.html /manifest.webmanifest
#         header @root Cache-Control "public, max-age=0, must-revalidate"
#
#         header {
#             X-Content-Type-Options "nosniff"
#             Referrer-Policy "strict-origin-when-cross-origin"
#             X-Frame-Options "DENY"
#             Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
#             -Server
#         }
#
#         try_files {path} /index.html
#         file_server
#     }
# }
