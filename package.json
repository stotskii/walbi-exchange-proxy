{
  "name": "walbi-exchange-proxy",
  "version": "0.1.0",
  "description": "Thin BFF that proxies exchange.walbi.cfd → walbi-mcp HTTP → gw.walbi.com / ws.walbi.com",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.10",
    "@hono/node-server": "^1.13.7",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
