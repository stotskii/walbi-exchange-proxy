# walbi-mcp HTTP endpoint + Bearer token
# In production the proxy talks to walbi-mcp via the Docker frontend network:
#   WALBI_MCP_URL=http://walbi-mcp-http:3001/mcp
# In local dev, against the public endpoint:
#   WALBI_MCP_URL=https://walbi-mcp.zw.walbi.cfd/mcp
WALBI_MCP_URL=https://walbi-mcp.zw.walbi.cfd/mcp
WALBI_MCP_BEARER=

# prod | stage
WALBI_ENV=prod

# Listen port
PORT=3002
